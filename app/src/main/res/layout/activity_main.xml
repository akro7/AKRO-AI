<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Red glow behind logo -->
    <View
        android:id="@+id/logo_glow"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="40dp"
        android:background="@drawable/glow_circle"
        android:alpha="0.45" />

    <!-- Gold accent glow -->
    <View
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="160dp"
        android:layout_marginStart="80dp"
        android:background="@drawable/glow_gold"
        android:alpha="0.3" />

    <!-- Logo image -->
    <ImageView
        android:id="@+id/logo_view"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="115dp"
        android:src="@mipmap/ic_launcher"
        android:scaleType="fitCenter"
        android:contentDescription="@string/app_name" />

    <!-- Top info area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="240dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/akro_text"
            android:textSize="30sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- Red divider under title -->
        <View
            android:layout_width="180dp"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/divider_red" />

        <TextView
            android:id="@+id/badge_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Built by AKRO"
            android:textColor="@color/akro_gold"
            android:textSize="12sp"
            android:letterSpacing="0.12" />

        <TextView
            android:id="@+id/subtitle_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="AI Assistant"
            android:textColor="@color/akro_subtext"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Center content: progress + button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ProgressBar
            android:id="@+id/progress_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/akro_blue"
            android:progressBackgroundTint="#30FF2D55"
            android:visibility="gone" />

        <TextView
            android:id="@+id/progress_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/akro_subtext"
            android:textSize="13sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/akro_blue"
            android:textSize="13sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/install_btn"
            android:layout_width="200dp"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:text="Install"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/btn_red"
            android:visibility="gone"
            android:elevation="6dp" />

    </LinearLayout>

    <!-- Bottom credit -->
    <TextView
        android:id="@+id/powered_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="28dp"
        android:text="Powered by AKRO"
        android:textColor="@color/akro_subtext"
        android:textSize="11sp"
        android:letterSpacing="0.1" />

</FrameLayout>
